diff --git a/assets/css/main.css b/assets/css/main.css
index 76bcf40..aff0b7b 100644
--- a/assets/css/main.css
+++ b/assets/css/main.css
@@ -2143,3 +2143,29 @@ footer {
   .gallery-modal-images { grid-template-columns: 1fr; }
   .gallery-modal-images img { height: auto; max-height: 24rem; }
 }
+
+/* Engagement tier cards (Starter / Growth / Custom) — reuses .offer-card shell */
+.tier-feature-list {
+  display: grid;
+  gap: var(--space-2);
+  padding-left: 0;
+  margin: 0;
+  list-style: none;
+}
+
+.tier-feature-list li {
+  position: relative;
+  padding-left: var(--space-4);
+  font-size: 0.8125rem;
+}
+
+.tier-feature-list li::before {
+  content: "";
+  position: absolute;
+  left: 0;
+  top: 0.5em;
+  width: 0.375rem;
+  height: 0.375rem;
+  background: var(--sage);
+  border-radius: 50%;
+}
